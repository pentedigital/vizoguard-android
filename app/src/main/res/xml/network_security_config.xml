<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block all cleartext traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Pin vizoguard.com API certificate -->
    <domain-config>
        <domain includeSubdomains="true">vizoguard.com</domain>
        <pin-set expiration="2027-01-01">
            <!-- Primary: vizoguard.com leaf certificate SPKI -->
            <pin digest="SHA-256">HDjm1NFkWIib39IMTmRtWwK15ZlN2mKz0sFuD8PFuA8=</pin>
            <!-- Backup: Let's Encrypt R10/R11 intermediate -->
            <pin digest="SHA-256">iFvwVyJSxnQdyaUvUERIf+8qk7gRze3612JMwoO3zdU=</pin>
        </pin-set>
    </domain-config>
</network-security-config>
